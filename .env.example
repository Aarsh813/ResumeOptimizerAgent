# ── LLM Provider ──────────────────────────────────────────────────────────────
# Choose your provider: groq | google | ollama
# Groq is recommended for free testing (14,400 req/day, no credit card needed)
LLM_PROVIDER=groq

# ── Groq (Free) ───────────────────────────────────────────────────────────────
# Get a free API key at: https://console.groq.com
# No credit card required. 14,400 requests/day, 30 req/min.
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
# Other good free Groq models:
#   llama-3.1-8b-instant    (faster, lighter)
#   gemma2-9b-it            (Google's Gemma via Groq)
#   mixtral-8x7b-32768      (large context window)

# ── Google Gemini ─────────────────────────────────────────────────────────────
# Get a key at: https://aistudio.google.com/apikey
# Switch to this by setting LLM_PROVIDER=google
GOOGLE_API_KEY=your_google_api_key_here
GEMINI_MODEL=gemini-2.0-flash
# Free limits: gemini-2.0-flash=1500/day | gemini-2.5-flash=20/day (too low)

# ── Ollama (Local / Offline) ──────────────────────────────────────────────────
# Install Ollama: https://ollama.com  then run: ollama pull llama3.2
# Switch to this by setting LLM_PROVIDER=ollama
OLLAMA_MODEL=llama3.2
OLLAMA_BASE_URL=http://localhost:11434

# ── Retry Config ──────────────────────────────────────────────────────────────
# Auto-retry on 429 rate limit errors
LLM_MAX_RETRIES=4
LLM_RETRY_DELAY=35
